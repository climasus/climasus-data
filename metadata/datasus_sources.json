{
  "schema_version": 1,
  "description": "Declarative DATASUS source catalog consumed by ClimaSUS clients.",
  "last_updated": "2026-04-26",
  "sources": {
    "datasus_ftp": {
      "protocol": "ftp",
      "base_url": "ftp://ftp.datasus.gov.br/dissemin/publicos",
      "official": true
    }
  },
  "template_variables": {
    "uf": "Two-letter state abbreviation.",
    "yyyy": "Four-digit year.",
    "yy": "Two-digit year.",
    "month": "Two-digit month.",
    "disease_code": "SINAN disease/condition code."
  },
  "systems": {
    "SIM-DO": {
      "source": "datasus_ftp",
      "family": "SIM",
      "file_format": "dbc",
      "temporal_granularity": "annual",
      "requires_month": false,
      "geographic_scope": "state",
      "filename_template": "DO{uf}{yyyy}.dbc",
      "url_templates": [
        {
          "status": "preliminary",
          "valid_from_year": 2022,
          "path_template": "SIM/PRELIM/DORES/DO{uf}{yyyy}.dbc"
        },
        {
          "status": "final",
          "path_template": "SIM/CID10/DORES/DO{uf}{yyyy}.dbc"
        }
      ]
    },
    "SIM-DOFET": {
      "source": "datasus_ftp",
      "family": "SIM",
      "file_format": "dbc",
      "temporal_granularity": "annual",
      "requires_month": false,
      "geographic_scope": "national",
      "filename_template": "DOFET{yy}.dbc",
      "url_templates": [
        {
          "status": "preliminary",
          "valid_from_year": 2022,
          "path_template": "SIM/PRELIM/DOFET/DOFET{yy}.dbc"
        },
        {
          "status": "final",
          "path_template": "SIM/CID10/DOFET/DOFET{yy}.dbc"
